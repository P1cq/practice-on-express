# Base URL of the backend API. Only VITE_-prefixed variables are exposed to
# the browser bundle by Vite — never put secrets here, this file ships in the
# built JS and is readable by anyone.
VITE_API_URL=http://localhost:3000

# Google OAuth Client ID — this is a public identifier (it's already visible
# in the redirect-based login URL), safe to expose in the browser bundle.
# The matching Client Secret stays backend-only (config/.env.dev), never here.
VITE_GOOGLE_CLIENT_ID=

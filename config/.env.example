PORT=3000
NODE_ENV=development

MONGO_URL=mongodb://localhost:27017
DB_NAME=mozo
MONGOOS_URL=mongodb://localhost:27017/mozo

URL_BACK=http://localhost:3000
URL_FRONT=http://localhost:5173

# "lax" works for same-site dev/prod setups (frontend + backend on the same
# registrable domain, e.g. different ports or subdomains). Use "none" only if
# the frontend is hosted on a fully different domain, and keep NODE_ENV=production
# in that case so the Secure flag is set (required by browsers for SameSite=None).
COOKIE_SAME_SITE=lax

# Google OAuth (get these from Google Cloud Console — never commit real values)
CLINT_ID=
CLINT_SECRET=

REDIS_URL=

# Secrets used to sign JWTs — generate long random strings, never reuse across environments
ACCESS_TOKEN=
REFRESH_TOKEN=

# AES-256 key used to encrypt phone numbers at rest — must be 32 bytes
KEY=

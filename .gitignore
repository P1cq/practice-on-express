# dependencies
node_modules/

# env files may contain machine-specific config; never commit real values
.env
.env.*
!.env.example
!**/.env.example

# build output
dist/
dist-ssr/

# user-uploaded content (avatars, message attachments) — runtime data, not source
uploads/*
!uploads/.gitkeep

# logs
logs
*.log
npm-debug.log*

# editor/OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
